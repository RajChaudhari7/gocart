generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id
  name  String
  email String
  image String
  cart  Json   @default("{}")

  ratings         Rating[]
  Address         Address[]
  store           Store?
  buyerOrders     Order[]         @relation("BuyerRelation")
  wishlist        Wishlist[]
  followingStores StoreFollower[]

  returnRequests  ReturnRequest[]
  userPreferences UserPreference[]
  activities      ProductView[]
  userActivity    UserActivity[]
  driverRatings   DriverRating[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  keywords    String[]
  mrp         Float
  price       Float
  quantity    Int      @default(0)
  images      String[]
  barcode     String?
  category    String
  storeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  size        String? // for clothing
  weight      String? // for grocery
  warranty    String? // for electronics
  attributes  Json? // for future dynamic fields
  subCategory String?
  isArchived  Boolean  @default(false)

  totalSales    Int   @default(0)
  totalViews    Int   @default(0)
  averageRating Float @default(0)

  featured         Boolean @default(false)
  featuredPriority Int     @default(0)

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  rating     Rating[]
  wishlist   Wishlist[]

  returnItems     ReturnItem[]
  userPreferences UserPreference[]
  views           ProductView[]
  userActivities  UserActivity[]

  @@index([barcode, storeId])
}

model SearchSynonym {
  id       String   @id @default(cuid())
  word     String
  synonyms String[]
}

////////////////////////////////////
// ✅ UPDATED ORDER STATUS ENUM
////////////////////////////////////
enum OrderStatus {
  ORDER_PLACED
  PACKED
  PROCESSING
  SHIPPED
  REACHED_SHOP
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERY_INITIATED
  DELIVERED
  CANCELLED
  RETURNED
  ORDER_CONFIRMED
  ORDER_PACKING
  ORDER_PACKED
  DRIVER_ASSIGNED
}

enum PaymentMethod {
  COD
  STRIPE
  RAZORPAY
}

////////////////////////////////////
// ✅ UPDATED ORDER MODEL
////////////////////////////////////
model Order {
  id     String      @id @default(cuid())
  total  Float
  status OrderStatus @default(ORDER_PLACED)

  /// Tracking History
  statusHistory Json @default("{}")

  commissionPercent Float?
  deliveryFee       Float?
  driverFee         Float?

  /// Delivery OTP
  deliveryOtp       String?
  deliveryOtpExpiry DateTime?
  otpVerified       Boolean   @default(false)
  otpVerifyAttempts Int       @default(0)
  otpResendCount    Int       @default(0)

  /// Driver Assignment
  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  driverAccepted Boolean   @default(false)
  assignedAt     DateTime?
  pickedAt       DateTime?
  deliveredAt    DateTime?

  driverRating DriverRating?

  /// Delivery Location
  deliveryLatitude  Float?
  deliveryLongitude Float?

  /// Customer / Store
  userId    String
  storeId   String
  addressId String

  assignmentExpiresAt DateTime?
  assignmentStatus    String?   @default("PENDING")
  reassignCount       Int       @default(0)
  rejectedDrivers     Json      @default("[]")

  /// Payment
  isPaid        Boolean       @default(false)
  paymentMethod PaymentMethod
  isCouponUsed  Boolean       @default(false)
  coupon        Json          @default("{}")

  /// Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Relations
  orderItems     OrderItem[]
  returnRequests ReturnRequest[]

  user    User    @relation("BuyerRelation", fields: [userId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  address Address @relation(fields: [addressId], references: [id])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OrderItem {
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([orderId, productId])
}

