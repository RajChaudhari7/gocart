model ReturnRequest {
  id        String    @id @default(cuid())
  orderId   String
  userId    String
  status    String    @default("PENDING")
  otp       String?
  otpExpiry DateTime?
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id])
  items ReturnItem[]
}

model ReturnItem {
  id        String @id @default(cuid())
  returnId  String
  productId String
  quantity  Int

  returnRequest ReturnRequest @relation(fields: [returnId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model Rating {
  id        String   @id @default(cuid())
  rating    Int
  review    String
  photos    String[]
  userId    String
  productId String
  orderId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  street    String
  city      String
  state     String
  zip       String
  country   String
  phone     String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  Order Order[]
  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  code        String   @id
  description String
  discount    Float
  forNewUser  Boolean
  forMember   Boolean  @default(false)
  isPublic    Boolean
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Store {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  description String
  username    String   @unique
  address     String
  status      String   @default("pending")
  isActive    Boolean  @default(false)
  logo        String
  email       String
  gst         String?
  latitude    Float?
  longitude   Float?
  contact     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       String?
  customCategory String?

  Product   Product[]
  Order     Order[]
  user      User            @relation(fields: [userId], references: [id])
  followers StoreFollower[]
}

model Driver {
  id String @id @default(cuid())

  name     String
  phone    String @unique
  password String

  vehicle   String?
  vehicleNo String?

  latitude     Float?
  longitude    Float?
  profilePhoto String?

  reassignCount Int @default(0)

  isOnline Boolean @default(false)
  isActive Boolean @default(true)

  totalDeliveries Int   @default(0)
  totalRatings    Int   @default(0)
  averageRating   Float @default(0)

  isAvailable Boolean @default(true)
  isLoggedIn  Boolean @default(false)
  sessionId   String?

  orders Order[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  driverRatings DriverRating[]
}

model DriverRating {
  id String @id @default(cuid())

  rating Int
  review String?

  driverId String
  orderId  String @unique
  userId   String

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([userId])
}

model PlatformSettings {
  id String @id @default(cuid())

  commissionPercent Float @default(10)

  deliveryFee Float @default(50)

  driverFee Float @default(30)

  freeDeliveryAbove Float @default(999999)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

model DriverApplication {
  id String @id @default(cuid())

  // Personal

  name String

  phone String @unique

  email String?

  password String

  profilePhoto String

  // Vehicle

  vehicleType String

  vehicleName String?

  vehicleNumber String

  // Documents

  driverLicense String

  aadharFront String

  aadharBack String

  rcBook String

  // Bank

  bankName String

  accountHolder String

  accountNumber String

  ifsc String

  upiId String?

  // Admin

  status DriverStatus @default(PENDING)

  adminRemark String?

  approvedAt DateTime?

  rejectedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model UserPreference {
  id String @id @default(cuid())

  userId    String
  productId String

  category    String
  subCategory String?

  purchasedAt DateTime @default(now())
  rating      Int?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([category])
}

model UserActivity {
  id String @id @default(cuid())

  userId String

  productId String?

  category String?

  action ActivityType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  product Product? @relation(fields: [productId], references: [id])
}

enum ActivityType {
  SEARCH
  VIEW
  CART
  WISHLIST
  PURCHASE
}

model ProductView {
  id String @id @default(cuid())

  userId    String
  productId String

  category    String?
  subCategory String?

  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model Wishlist {
  id String @id @default(cuid())

  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model StoreFollower {
  id String @id @default(cuid())

  userId  String
  storeId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
}
